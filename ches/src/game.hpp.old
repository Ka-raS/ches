#pragma once

#include <cmath>

#include <raylib.h>

#include "cheslib/engine.hpp"

namespace ches {

namespace cl = cheslib;

enum State {
    SelectingPiece,
    SelectingDestination,
    PromotingPawn,
    EnginePlaying,
    GameOver
};

constexpr ::Rectangle BoardRectangle{
    .x = 88, //
    .y = 88,
    .width = 1024,
    .height = 1024
};
constexpr int SquareSize = BoardRectangle.width / 8;

constexpr ::Rectangle UIPanelRectangle{
    .x = 1200, //
    .y = 88,
    .width = 312,
    .height = 1024
};

// inside UIPanelRectangle:
constexpr ::Rectangle PromoSelectionRectangle{
    .x = UIPanelRectangle.x + (UIPanelRectangle.width - SquareSize) / 2, //
    .y = 1200 - 88 - SquareSize * 4 - (UIPanelRectangle.width - SquareSize) / 2,
    .width = SquareSize,
    .height = SquareSize * 4
};

constexpr ::Rectangle NewGameButtonRectangle{
    .x = UIPanelRectangle.x + 50, //
    .y = UIPanelRectangle.y + 50,
    .width = UIPanelRectangle.width - 100,
    .height = 40
};

class Game {
  public:
    Game() = default;

    void run() {
        ::SetConfigFlags(::FLAG_WINDOW_RESIZABLE | ::FLAG_MSAA_4X_HINT);
        ::InitWindow(1600, 1200, "Ches");
        ::EnableEventWaiting();
        rescale();

        _board_texture = ::LoadTexture("assets/pieces-spritesheet.png");
        ::GenTextureMipmaps(&_board_texture);
        ::SetTextureFilter(_board_texture, TEXTURE_FILTER_TRILINEAR);

        _font = ::LoadFont("assets/NotoSans-Bold.ttf");
        ::SetTextureFilter(_font.texture, TEXTURE_FILTER_BILINEAR);

        _legal_moves = _engine.generate_legal_moves();

        while (!::WindowShouldClose()) {
            update();
            render();
        }

        ::UnloadTexture(_board_texture);
        ::UnloadFont(_font);
        ::CloseWindow();
    }

    void rescale() {
        float width = (float)::GetScreenWidth();
        float height = (float)::GetScreenHeight();
        float scale = std::min(width / 1600, height / 1200);

        _camera.zoom = scale;
        _camera.offset.x = (width - 1600 * scale) / 2;
        _camera.offset.y = (height - 1200 * scale) / 2;
    }

    void set_cursor(::MouseCursor cursor) {
        if (_cursor != cursor) {
            _cursor = cursor;
            ::SetMouseCursor(cursor);
        }
    }

    cl::Square screen_to_square(::Vector2 mouse, cl::Side side_to_move) const {
        int file = (mouse.x - BoardRectangle.x) / 128;
        int rank = (mouse.y - BoardRectangle.y) / 128;

        if (side_to_move == cl::White) {
            rank = cl::Rank8 - rank;
        } else {
            file = cl::FileH - file;
        }

        return cl::types::square_of(cl::File(file), cl::Rank(rank));
    }

    void update() {
        if (::IsWindowResized()) {
            rescale();
        }

        switch (_state) {
        case SelectingPiece: {
            const ::Vector2 mouse = ::GetScreenToWorld2D(::GetMousePosition(), _camera);
            const bool clicked = ::IsMouseButtonPressed(::MOUSE_BUTTON_LEFT);

            if (::CheckCollisionPointRec(mouse, NewGameButtonRectangle)) {
                set_cursor(::MOUSE_CURSOR_POINTING_HAND);

                if (clicked) {
                    _engine.new_game();
                    _user = !_user;
                    _selected_piece = cl::SquareCNT;
                    _state = SelectingPiece;
                    _legal_moves = _engine.generate_legal_moves();
                }

                break;
            }

            if (!::CheckCollisionPointRec(mouse, BoardRectangle)) {
                set_cursor(::MOUSE_CURSOR_DEFAULT);
                break;
            }

            cl::Square square = screen_to_square(mouse, _user);
            cl::Piece piece = _engine.board()[square];

            if (piece >= cl::PieceCNT || _user != cl::types::side_of(piece)) {
                set_cursor(::MOUSE_CURSOR_DEFAULT);
                break;
            }

            set_cursor(::MOUSE_CURSOR_POINTING_HAND);

            if (clicked) {
                _state = SelectingDestination;
                _selected_piece = square;
                TraceLog(LOG_INFO, "Selected piece %d on square %d", piece, square);
            }

            break;
        }

        case SelectingDestination: {
            const ::Vector2 mouse = ::GetScreenToWorld2D(::GetMousePosition(), _camera);
            const bool clicked = ::IsMouseButtonPressed(::MOUSE_BUTTON_LEFT);

            if (::CheckCollisionPointRec(mouse, NewGameButtonRectangle)) {
                set_cursor(::MOUSE_CURSOR_POINTING_HAND);

                if (clicked) {
                    _engine.new_game();
                    _user = !_user;
                    _selected_piece = cl::SquareCNT;
                    _state = SelectingPiece;
                    _legal_moves = _engine.generate_legal_moves();
                }

                break;
            }

            if (!::CheckCollisionPointRec(mouse, BoardRectangle)) {
                set_cursor(::MOUSE_CURSOR_DEFAULT);
                break;
            }

            const cl::Square dest_square = screen_to_square(mouse, _user);
            const cl::Piece piece = _engine.board()[dest_square];
            const bool is_our_piece = piece < cl::PieceCNT && _user == cl::types::side_of(piece);
            const cl::Move *move = _legal_moves.find(_selected_piece, dest_square);

            // if mouse not at a clickable
            if (!move && !is_our_piece) {
                set_cursor(::MOUSE_CURSOR_DEFAULT);

                if (clicked) {
                    _selected_piece = cl::SquareCNT;
                    _state = SelectingPiece;
                }

                break;
            }

            set_cursor(::MOUSE_CURSOR_POINTING_HAND);

            // if hovering a clickable
            if (!clicked) {
                break;
            }

            assert(!move == is_our_piece);

            // if clicked one of our pieces
            if (is_our_piece) {
                _selected_piece = dest_square;
                break;
            }

            if (move->is_promotion()) {
                _state = PromotingPawn;
                _pending_move = *move;
                break;
            }

            bool is_valid = _engine.try_do_move(*move);
            assert(is_valid);
            bool testing = true;

            if (_engine.is_game_over()) {
                _state = GameOver;
            } else if (testing) {
                _user = !_user;
                _selected_piece = cl::SquareCNT;
                _state = SelectingPiece;
                _legal_moves = _engine.generate_legal_moves();
            } else {
                _state = EnginePlaying;
            }

            break;
        }

        case PromotingPawn: {
            const ::Vector2 mouse = ::GetScreenToWorld2D(::GetMousePosition(), _camera);
            const bool clicked = ::IsMouseButtonPressed(::MOUSE_BUTTON_LEFT);

            if (::CheckCollisionPointRec(mouse, NewGameButtonRectangle)) {
                set_cursor(::MOUSE_CURSOR_POINTING_HAND);

                if (clicked) {
                    _engine.new_game();
                    _user = !_user;
                    _selected_piece = cl::SquareCNT;
                    _state = SelectingPiece;
                    _legal_moves = _engine.generate_legal_moves();
                }

                break;
            }

            if (!::CheckCollisionPointRec(mouse, PromoSelectionRectangle)) {
                set_cursor(::MOUSE_CURSOR_DEFAULT);
                break;
            }

            set_cursor(::MOUSE_CURSOR_POINTING_HAND);
            if (!clicked) {
                break;
            }

            int index = (mouse.y - PromoSelectionRectangle.y) / SquareSize;
            cl::PieceType promo = cl::PieceType(cl::Knight + index);
            _pending_move.set_promoted_piece(promo);

            assert(_legal_moves.has(_pending_move));
            bool is_valid = _engine.try_do_move(_pending_move);
            assert(is_valid);

            bool testing = true;

            if (_engine.is_game_over()) {
                _state = GameOver;
            } else if (testing) {
                _user = !_user;
                _selected_piece = cl::SquareCNT;
                _state = SelectingPiece;
                _legal_moves = _engine.generate_legal_moves();
            } else {
                _state = EnginePlaying;
            }

            break;
        }

        case EnginePlaying: {
            break;
        }

        case GameOver: {
            const ::Vector2 mouse = ::GetScreenToWorld2D(::GetMousePosition(), _camera);
            const bool clicked = ::IsMouseButtonPressed(::MOUSE_BUTTON_LEFT);

            if (::CheckCollisionPointRec(mouse, NewGameButtonRectangle)) {
                set_cursor(::MOUSE_CURSOR_POINTING_HAND);

                if (clicked) {
                    _engine.new_game();
                    _user = !_user;
                    _selected_piece = cl::SquareCNT;
                    _state = SelectingPiece;
                    _legal_moves = _engine.generate_legal_moves();
                }

                break;
            }

            break;
        }
        } // switch
    }

    void render() const {
        ::BeginDrawing();
        ::ClearBackground(::Color{0x30, 0x2E, 0x2B, 0xFF}); // #302E2BFF
        ::BeginMode2D(_camera);

        draw_board();
        draw_ui();

        ::EndMode2D();
        ::EndDrawing();
    }

    ::Vector2 square_to_screen(cl::Square square) const {
        const cl::Rank rank = cl::types::rank_of(square);
        const cl::File file = cl::types::file_of(square);

        int col = _user == cl::White ? file : cl::FileH - file;
        int row = _user == cl::White ? cl::Rank8 - rank : rank;

        return {.x = col * SquareSize + BoardRectangle.x, .y = row * SquareSize + BoardRectangle.y};
    }

    void draw_board() const {
        constexpr ::Color Light{0xEF, 0xD8, 0xB4, 0xFF}; // #EFD8B4FF
        constexpr ::Color Dark{0xB4, 0x87, 0x62, 0xFF};  // #B48762FF

        for (cl::Square sq = cl::SquareA1; sq <= cl::SquareH8; ++sq) {
            const cl::Rank rank = cl::types::rank_of(sq);
            const cl::File file = cl::types::file_of(sq);

            // flips view if black to move
            const ::Vector2 position{
                .x = (_user == cl::White ? file : cl::FileH - file) * SquareSize + BoardRectangle.x,
                .y = (_user == cl::White ? cl::Rank8 - rank : rank) * SquareSize + BoardRectangle.y
            };

            // draw square
            const bool is_light_square = (file % 2) != (rank % 2);
            ::DrawRectangle(position.x, position.y, SquareSize, SquareSize, is_light_square ? Light : Dark);
        }

        for (cl::Square sq = cl::SquareA1; sq <= cl::SquareH8; ++sq) {
            const cl::Rank rank = cl::types::rank_of(sq);
            const cl::File file = cl::types::file_of(sq);

            // flips view if black to move
            const ::Vector2 position{
                .x = (_user == cl::White ? file : cl::FileH - file) * SquareSize + BoardRectangle.x,
                .y = (_user == cl::White ? cl::Rank8 - rank : rank) * SquareSize + BoardRectangle.y
            };

            // draw square
            const bool is_light_square = (file % 2) == (rank % 2);

            if (sq == _selected_piece) {
                ::DrawRectangle(
                    position.x, position.y, SquareSize, SquareSize, ::Color{0xAB, 0xCC, 0x20, 0x80} // #ABCC2080
                );

                for (cl::Move move : _legal_moves) {
                    if (move.from() != sq) {
                        continue;
                    }
                    cl::Square to = move.to();
                    cl::Rank to_rank = cl::types::rank_of(to);
                    cl::File to_file = cl::types::file_of(to);
                    int x = (_user == cl::White ? to_file : cl::FileH - to_file) * SquareSize + BoardRectangle.x;
                    int y = (_user == cl::White ? cl::Rank8 - to_rank : to_rank) * SquareSize + BoardRectangle.y;

                    ::DrawCircle(
                        x + SquareSize / 2, y + SquareSize / 2, SquareSize / 6, ::Color{18, 82, 28, 121}
                    ); // #20CCAB40
                }
            }

            { // draw rank/file text
                ::Color color = is_light_square ? Dark : Light;
                cl::File draw_file = _user == cl::White ? cl::FileH : cl::FileA;
                cl::Rank draw_rank = _user == cl::White ? cl::Rank1 : cl::Rank8;

                if (file == draw_file) {
                    char text[2] = {char('1' + rank), '\0'};
                    ::Vector2 m = ::MeasureTextEx(_font, text, _font.baseSize, 0);
                    float tx = position.x + SquareSize - m.x * 1.5F;
                    float ty = position.y;
                    ::DrawTextEx(_font, text, {tx, ty}, _font.baseSize, 0, color);
                }

                if (rank == draw_rank) {
                    char text[2] = {char('a' + file), '\0'};
                    ::Vector2 m = ::MeasureTextEx(_font, text, _font.baseSize, 0);
                    float tx = position.x + m.x / 2;
                    float ty = position.y + SquareSize - m.y;
                    ::DrawTextEx(_font, text, {tx, ty}, _font.baseSize, 0, color);
                }
            }

            // draw piece
            cl::Piece piece = _engine.board()[sq];
            if (piece < cl::PieceCNT) {
                ::Rectangle source{.x = (float)piece * SquareSize, .y = 0, .width = SquareSize, .height = SquareSize};
                ::DrawTextureRec(_board_texture, source, position, ::WHITE);
            }
        }
    }

    void draw_ui() const {
        ::DrawRectangleRec(UIPanelRectangle, ::Color{0x20, 0x20, 0x20, 0x80}); // #20202080

        { // draw new game button
            ::Vector2 text_size = ::MeasureTextEx(_font, "New Game", _font.baseSize, 0);
            ::Vector2 text_pos{
                .x = NewGameButtonRectangle.x + (NewGameButtonRectangle.width - text_size.x) / 2,
                .y = NewGameButtonRectangle.y + (NewGameButtonRectangle.height - text_size.y) / 2
            };
            ::DrawRectangleRec(NewGameButtonRectangle, ::Color{0x20, 0x20, 0x20, 0x80}); // #20202080
            ::DrawTextEx(_font, "New Game", text_pos, _font.baseSize, 0, ::WHITE);
        }

        if (_state == PromotingPawn) {
            ::DrawRectangleRec(PromoSelectionRectangle, ::Color{0x20, 0x20, 0x20, 0x80}); // #20202080
            for (cl::PieceType type = cl::Knight; type <= cl::Queen; ++type) {
                cl::Piece piece = cl::types::piece_of(_user, type);
                ::Rectangle source{.x = (float)piece * SquareSize, .y = 0, .width = SquareSize, .height = SquareSize};
                ::Vector2 position{
                    .x = PromoSelectionRectangle.x, .y = PromoSelectionRectangle.y + (type - cl::Knight) * SquareSize
                };
                ::DrawTextureRec(_board_texture, source, position, ::WHITE);
            }
        }
    }

    State _state{SelectingPiece};
    cl::Square _selected_piece{cl::SquareCNT};
    cl::Move _pending_move{};

    cl::Engine _engine{};
    cl::Side _user{cl::White};
    cl::Array<Move, 256> _legal_moves{};

    ::Camera2D _camera{.zoom = 1.0F};
    ::Texture2D _board_texture{};
    ::Font _font{};
    ::MouseCursor _cursor{MOUSE_CURSOR_DEFAULT};
};

} // namespace ches
