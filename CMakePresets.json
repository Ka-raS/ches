{
    "version": 6,
    "configurePresets": [
        {
            "name": "debug",
            "binaryDir": "out/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            }
        },
        {
            "name": "release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": true,
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": true
            }
        },
        {
            "name": "pgo-generate",
            "inherits": "release",
            "binaryDir": "out/build/pgo-generate",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-fno-exceptions -fno-omit-frame-pointer -fno-rtti -fprofile-instr-generate -fprofile-update=atomic -funroll-loops -g -pipe"
            }
        },
        {
            "name": "pgo-use",
            "inherits": "release",
            "binaryDir": "out/build/pgo-use",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-fno-exceptions -fno-omit-frame-pointer -fno-rtti -fprofile-use=${sourceDir}/out/build/pgo-generate/ches/default.profdata -funroll-loops -g -pipe"
            }
        }
    ]
}